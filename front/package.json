{
  "name": "englishlover-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && npm run check:styles && npm run check:components && npm run check:catalog && npm run check:no-business-data",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "check:styles": "node scripts/check-style-boundaries.mjs",
    "check:no-business-data": "node scripts/check-no-business-data.mjs",
    "verify": "npm run typecheck && npm run lint && npm run build",
    "check:components": "node scripts/check-component-compliance.mjs",
    "check:catalog": "node scripts/check-component-catalog.mjs"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "prettier": "^3.0.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "tailwindcss": "^4.1.0",
    "typescript": "~5.8.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.2.0"
  }
}
