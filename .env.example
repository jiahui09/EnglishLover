# EnglishLover Docker/Compose deployment template.
# Copy this file to `.env` before running Compose on a target machine.
# Do not commit real secrets in `.env`.

# Image registry and version tag. Keep REGISTRY empty for local image names.
REGISTRY=
IMAGE_TAG=local
PLATFORM=linux/amd64

# Optional build base image overrides for restricted networks or internal mirrors.
# Defaults use Docker Hub official images; override all three together if your environment requires a mirror.
GO_BASE_IMAGE=golang:1.26-alpine
NODE_BASE_IMAGE=node:26-alpine
ALPINE_BASE_IMAGE=alpine:3.22

# Host ports exposed by Compose. Change these if the target machine already uses them.
FRONTEND_PORT=4173
API_PORT=18080

# Container ports. Usually do not change.
FRONTEND_PREVIEW_PORT=4173
API_CONTAINER_PORT=8080

# Database and cache.
POSTGRES_DB=englishlover
POSTGRES_USER=englishlover
POSTGRES_PASSWORD=change-me-before-deploy
POSTGRES_PORT=15432
REDIS_PORT=16379

# API runtime settings.
APP_VERSION=1.0.0
AUTO_MIGRATE=true
COOKIE_SECURE=false
CONTRACT_TEST_EMAIL=learner@example.com
CONTRACT_TEST_PASSWORD=learner-password

# Frontend container proxies /api/* to the API service inside the Compose network.
DEPLOY_API_ORIGIN=http://api:8080
